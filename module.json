{
  "id": "docs",
  "slug": "docs",
  "name": "Docs",
  "namespace": "modula.docs",
  "version": "1.0.2",
  "package_kind": "module",
  "class": "surface",
  "placements": [
    "sidebar",
    "standalone_page"
  ],
  "runtime": "sandbox",
  "runtime_renderer": "docs_host",
  "bundle_entry": "index.html",
  "entry": "index.html",
  "entry_points": {
    "frontend": "frontend/routes/+page.svelte",
    "backend": "backend/router.py"
  },
  "route": "/docs",
  "routes": [
    {
      "path": "/docs",
      "kind": "surface",
      "label": "Docs"
    }
  ],
  "surfaces": [
    {
      "type": "sidebar_page",
      "id": "docs-home",
      "title": "Docs",
      "route": "/docs"
    },
    {
      "type": "standalone_page",
      "id": "docs-standalone",
      "title": "Docs",
      "route": "/docs"
    }
  ],
  "widgets": [],
  "permissions": [],
  "capabilities_provided": [
    "docs.read",
    "docs.search",
    "docs.navigation",
    "docs.guides"
  ],
  "capabilities_required": [],
  "capabilities_optional": [],
  "actions_provided": [
    {
      "id": "docs.search.query",
      "title": "Search Docs",
      "capability": "docs.search"
    }
  ],
  "triggers_emitted": [
    {
      "id": "docs.search.requested",
      "title": "Docs Search Requested"
    }
  ],
  "jobs_provided": [
    {
      "id": "docs.index.rebuild",
      "title": "Rebuild Docs Index",
      "schedule_supported": true
    }
  ],
  "workflows_provided": [
    {
      "id": "docs.search.assist",
      "title": "Docs Search Assist",
      "steps": [
        "docs.search.query"
      ]
    }
  ],
  "agent_roles": [
    {
      "id": "docs.assistant",
      "title": "Docs Assistant",
      "capabilities": [
        "docs.read",
        "docs.search"
      ]
    }
  ],
  "compatibility": {
    "modula_core": ">=1.0.0",
    "api_version": "1"
  },
  "update_channel": "stable",
  "hooks": {}
}
